# JARVIS CONFIGURATION - ENVIRONMENT VARIABLES
# ===============================================
# Copy this file to .env and fill in your actual values

# ========== OPENAI API ==========
# Get your API key from: https://platform.openai.com/api-keys
# ⭐ FREE OPTION: Sign up for free $5 credits
# Instructions below 👇

# Option 1: OpenAI API Key (RECOMMENDED - includes free credits)
OPENAI_API_KEY=your-api-key-here

# ========== ASSISTANT CONFIGURATION ==========
ASSISTANT_NAME=Mitra
USER_NAME=Smaran

# ========== VOICE SETTINGS ==========
# Speech rate: 50-300 words per minute
VOICE_RATE=170

# Volume: 0.0 to 1.0
VOICE_VOLUME=1.0

# Voice index: 0 = Male, 1 = Female
VOICE_INDEX=0

# Energy threshold for microphone (higher = less sensitive)
MICROPHONE_THRESHOLD=4000

# ========== FEATURES ==========
# Enable/disable specific features
ENABLE_VECTOR_DB=true
VECTOR_DB_TYPE=faiss
ENABLE_MEMORY=true
ENABLE_WEB_INTERFACE=false

# ========== DEBUGGING ==========
DEBUG_MODE=false
LOG_LEVEL=INFO

# ========== OPTIONAL APIs ==========
# Add other API keys as needed for future integrations
# WEATHER_API_KEY=your-key-here
# SPOTIFY_API_KEY=your-key-here
# GMAIL_API_KEY=your-key-here
